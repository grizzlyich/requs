{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pip install -r requirements.txt",
  "buildCommand": "bash build_files.sh",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/wsgi.py"
    }
  ],
  "functions": {
    "wsgi.py": {
      "runtime": "python3.12",
      "maxDuration": 30
    }
  }
}
